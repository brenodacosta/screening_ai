# =========================================================
# screening_ai — environment configuration template
# Copy to `.env` and fill in real values. `.env` is gitignored.
# =========================================================

# --- LLM (GitHub Models by default; any OpenAI-compatible endpoint works) ---
# For GitHub Models the api key is your fine-grained PAT. The PAT must have the
# Models account permission set to a level that allows inference (read-only on
# Models only grants catalog access, not /chat/completions).
GITHUB_PAT=replace-me

# OpenAI-compatible endpoint base. Examples:
#   GitHub Models   : https://models.github.ai/inference
#   Gemini          : https://generativelanguage.googleapis.com/v1beta/openai/
#   Groq            : https://api.groq.com/openai/v1
#   Ollama (local)  : http://localhost:11434/v1
LLM_BASE_URL=https://models.github.ai/inference

# Model id as exposed by the endpoint:
#   GitHub Models   : openai/gpt-4o-mini, openai/gpt-4o, meta/meta-llama-3.1-70b-instruct, ...
#   Gemini          : gemini-2.0-flash, gemini-2.0-flash-lite
#   Groq            : llama-3.3-70b-versatile, llama-3.1-8b-instant
#   Ollama          : llama3.1, qwen2.5, ...
MODEL_NAME=openai/gpt-4o-mini

# --- Paths (inside the api container) ---
DATA_DIR=./data
JD_PATH=./jobs/delivery_driver.md
CHECKPOINT_DB_PATH=./data/checkpoints.db

# --- Behavior ---
# Inactivity = how long a conversation can sit idle before the
# sweeper marks it `abandoned`. 600s = 10 min (per process design).
INACTIVITY_TIMEOUT_SECONDS=600
# How often the sweeper scans for stale conversations.
INACTIVITY_SWEEP_INTERVAL_SECONDS=60

# Default starting language for the bilingual greeting flow.
# Allowed: es | en. Bidirectional switching after that.
DEFAULT_LANGUAGE=es

# --- Inter-service ---
# Used by the Chainlit `ui` to reach the FastAPI `api`.
# In docker-compose this is `http://api:8000`; locally `http://localhost:8000`.
API_BASE_URL=http://localhost:8000

# --- Optional: LangSmith tracing ---
LANGSMITH_TRACING=0
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=screening-ai

# --- App metadata ---
AGENT_VERSION=0.1.0
JOB_ID=delivery_driver
